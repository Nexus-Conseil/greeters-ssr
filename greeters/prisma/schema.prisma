generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN @map("super_admin")
  ADMIN       @map("admin")
  EDITOR      @map("editor")
}

enum PageStatus {
  DRAFT     @map("draft")
  PENDING   @map("pending")
  PUBLISHED @map("published")
  ARCHIVED  @map("archived")
}

enum PreviewStatus {
  PENDING   @map("pending")
  VALIDATED @map("validated")
  REJECTED  @map("rejected")
  EXPIRED   @map("expired")
}

enum AiChatRole {
  USER      @map("user")
  ASSISTANT @map("assistant")
}

model User {
  id           String          @id @default(uuid()) @db.Uuid
  email        String          @unique
  name         String
  passwordHash String          @map("password_hash")
  role         UserRole        @default(EDITOR)
  createdBy    String?         @map("created_by") @db.Uuid
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  sessions     Session[]
  resets       PasswordReset[]

  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordReset {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  email     String
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_resets")
}

model Page {
  id               String       @id @default(uuid()) @db.Uuid
  locale           String       @default("fr")
  title            String
  slug             String
  metaDescription  String?      @map("meta_description")
  metaKeywords     String?      @map("meta_keywords")
  sections         Json         @default("[]")
  status           PageStatus   @default(DRAFT)
  isInMenu         Boolean      @default(false) @map("is_in_menu")
  menuOrder        Int          @default(0) @map("menu_order")
  menuLabel        String?      @map("menu_label")
  currentVersion   Int          @default(1) @map("current_version")
  publishedVersion Int?         @map("published_version")
  createdBy        String       @map("created_by") @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy        String?      @map("updated_by") @db.Uuid
  updatedAt        DateTime?    @map("updated_at") @db.Timestamptz(6)
  versions         PageVersion[]

  @@unique([locale, slug])
  @@index([locale, slug])
  @@index([locale, status])
  @@index([isInMenu, menuOrder])
  @@map("pages")
}

model PageVersion {
  id              String      @id @default(uuid()) @db.Uuid
  pageId          String      @map("page_id") @db.Uuid
  versionNumber   Int         @map("version_number")
  content         Json
  status          PageStatus  @default(DRAFT)
  createdBy       String      @map("created_by") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  approvedBy      String?     @map("approved_by") @db.Uuid
  approvedAt      DateTime?   @map("approved_at") @db.Timestamptz(6)
  rejectionReason String?     @map("rejection_reason")
  page            Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, versionNumber])
  @@index([status])
  @@index([createdAt])
  @@map("page_versions")
}

model Menu {
  id        String    @id
  items     Json      @default("[]")
  updatedBy String?   @map("updated_by") @db.Uuid
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(6)

  @@map("menus")
}

model Document {
  id               String   @id @default(uuid()) @db.Uuid
  filename         String
  originalFilename String   @map("original_filename")
  filePath         String   @map("file_path")
  fileSize         BigInt   @map("file_size")
  mimeType         String   @map("mime_type")
  category         String
  description      String?
  uploadedBy       String   @map("uploaded_by")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([category])
  @@index([createdAt])
  @@map("documents")
}

model HomeSection {
  id          String    @id @default(uuid()) @db.Uuid
  sectionType String    @unique @map("section_type")
  content     Json?
  items       Json?
  order       Int       @default(0)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([order])
  @@map("home_sections")
}

model PageContent {
  id        String   @id @default(uuid()) @db.Uuid
  pageId    String   @unique @map("page_id")
  content   Json
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("page_contents")
}

model PagePreview {
  id         String        @id @default(uuid()) @db.Uuid
  pageId     String        @map("page_id")
  newContent Json          @map("new_content")
  status     PreviewStatus @default(PENDING)
  createdBy  String        @map("created_by") @db.Uuid
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([pageId])
  @@index([status])
  @@map("page_previews")
}

model PageEdit {
  id             String   @id @default(uuid()) @db.Uuid
  pageId         String   @map("page_id")
  prompt         String
  changesSummary String?  @map("changes_summary")
  editorId       String?  @map("editor_id") @db.Uuid
  editorName     String?  @map("editor_name")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([pageId])
  @@index([createdAt])
  @@map("page_edits")
}

model AiChatSession {
  id             String          @id @default(uuid()) @db.Uuid
  createdBy      String          @map("created_by") @db.Uuid
  locale         String          @default("fr")
  title          String?
  latestDraft    Json?           @map("latest_draft")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  messages       AiChatMessage[]

  @@index([createdBy, createdAt])
  @@index([locale, updatedAt])
  @@map("ai_chat_sessions")
}

model AiChatMessage {
  id          String      @id @default(uuid()) @db.Uuid
  sessionId   String      @map("session_id") @db.Uuid
  role        AiChatRole
  content     String
  generatedPage Json?     @map("generated_page")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  session     AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("ai_chat_messages")
}